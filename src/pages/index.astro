---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Milena Giacomini">
  <main>
    <h1>Milena Giacomini</h1>

    <p id="typing-text"></p>

    <nav>
      <a href="/milena-giacomini/sobre">→ Sobre mim</a>

      <a href="/milena-giacomini/curriculo">→ Currículo</a>

      <a href="/milena-giacomini/projetos">→ Projetos</a>

      <a href="/milena-giacomini/colaboracoes">→ Colaborações</a>

      <a href="/milena-giacomini/contato">→ Contato</a>

      <a href="/milena-giacomini/blog">→ Blog</a>
    </nav>

    <script>
  const text =
    "Jornalista, especialista em estratégia de conteúdo e distribuição";

  const element = document.getElementById("typing-text");

  if (element) {
    const el = element; // narrow for closures
    let index = 0;

    function type() {
      if (index < text.length) {
        el.textContent += text.charAt(index);
        index++;
        setTimeout(type, 40);
      }
    }

    type();
  }
</script>
  </main>
</Layout>